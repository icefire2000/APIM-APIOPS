<policies>
	<inbound>
		<base />
		<choose>
			<when condition="@(!string.Equals(context.Request.Method, &quot;POST&quot;, StringComparison.OrdinalIgnoreCase))">
				<return-response>
					<set-status code="405" reason="Method Not Allowed" />
					<set-header name="Allow" exists-action="override">
						<value>POST</value>
					</set-header>
					<set-body>{"error":"method_not_allowed"}</set-body>
				</return-response>
			</when>
		</choose>
		<set-variable name="ct" value="@((string)context.Request.Headers.GetValueOrDefault(&quot;Content-Type&quot;,&quot;&quot;))" />
		<choose>
			<when condition="@(!(((string)context.Variables[&quot;ct&quot;]) ?? string.Empty).ToLowerInvariant().Contains(&quot;application/x-www-form-urlencoded&quot;))">
				<return-response>
					<set-status code="415" reason="Unsupported Media Type" />
					<set-header name="Content-Type" exists-action="override">
						<value>application/json</value>
					</set-header>
					<set-body>{"error":"content_type_must_be_application_x_www_form_urlencoded"}</set-body>
				</return-response>
			</when>
		</choose>
		<set-variable name="authHeader" value="@(context.Request.Headers.GetValueOrDefault(&quot;Authorization&quot;, &quot;&quot;))" />
		<set-variable name="authDecoded" value="@{   
            var auth = (string)context.Variables[&quot;authHeader&quot;] ?? string.Empty;  
            if (auth.StartsWith(&quot;Basic &quot;, StringComparison.OrdinalIgnoreCase)) {   
                var encoded = auth.Substring(6).Trim();  
                try {  
                    var bytes = System.Convert.FromBase64String(encoded);  
                    return System.Text.Encoding.UTF8.GetString(bytes);  
                } catch {  
                    return string.Empty;  
                }  
            }  
            return string.Empty;  
        }" />
		<set-variable name="client_id" value="@{
        var decoded = (string)context.Variables["authDecoded"] ?? string.Empty;
        var idx = decoded.IndexOf(':');
        var parts = decoded.Split(':');  
        return parts.Length > 0 ? parts[0] : string.Empty;  
    }" />
		<set-variable name="client_secret" value="@{
        var decoded = (string)context.Variables["authDecoded"] ?? string.Empty;
        var idx = decoded.IndexOf(':');
        var parts = decoded.Split(':');  
        return parts.Length > 0 ? parts[1] : string.Empty;  
    }" />
		<choose>
			<when condition="@(!(new string[] { &quot;test-client&quot; }).Contains(((string)context.Variables[&quot;client_id&quot;]) ?? string.Empty))">
				<return-response>
					<set-status code="403" reason="Forbidden" />
					<set-header name="Content-Type" exists-action="override">
						<value>application/json</value>
					</set-header>
					<set-body>{"error":"client_not_whitelisted"}</set-body>
				</return-response>
			</when>
		</choose>
		<set-variable name="origForm" value="@((context.Request.Body.As<string>(preserveContent: true)) ?? string.Empty)" />
		<set-variable name="forwardBody" value="@{
        var orig = (string)context.Variables["origForm"] ?? string.Empty;
        var cid  = (string)context.Variables["client_id"] ?? string.Empty;
        var csec = (string)context.Variables["client_secret"] ?? string.Empty;

        var cidEnc  = System.Uri.EscapeDataString(cid);
        var csecEnc = System.Uri.EscapeDataString(csec);

        var sep = string.IsNullOrEmpty(orig) ? "" : "&";
        return orig + sep + "client_id=" + cidEnc + "&client_secret=" + csecEnc;
    }" />
		<send-request mode="new" response-variable-name="tokenResp" timeout="20" ignore-error="false">
			<set-url>https://forgerock-green.preprod-gcdm.cn-north-1.aws.cloud.bmw/am/oauth2/access_token</set-url>
			<set-method>POST</set-method>
			<set-header name="Content-Type" exists-action="override">
				<value>application/x-www-form-urlencoded</value>
			</set-header>
			<set-body>@(context.Variables["forwardBody"] as string)</set-body>
		</send-request>
		<!-- 注释掉send-request部分，直接返回mock响应 -->
		<!--
        <return-response>
            <set-status code="200" reason="OK" />
            <set-header name="Content-Type" exists-action="override">
                <value>application/json</value>
            </set-header>
            <set-body>{"access_token":"mock_token","token_type":"Bearer","expires_in":3600}</set-body>
        </return-response>
        -->
		<set-variable name="tokenBody" value="@{  
            var resp = context.Variables.ContainsKey(&quot;tokenResp&quot;) ? (IResponse)context.Variables[&quot;tokenResp&quot;] : null;  
            return resp?.Body?.As<string>() ?? &quot;&quot;;  
        }" />
		<set-variable name="tokenJson" value="@{  
            try {  
                return Newtonsoft.Json.Linq.JObject.Parse((string)context.Variables[&quot;tokenBody&quot;]);  
            } catch {  
                return null;  
            }  
        }" />
		<!-- 提取 token 字段 -->
		<set-variable name="access_token" value="@( (string)((context.Variables["tokenJson"] as JObject)?["access_token"]) ?? "" )" />
		<set-variable name="refresh_token" value="@( (string)((context.Variables["tokenJson"] as JObject)?["refresh_token"]) ?? "" )" />
		<set-variable name="refresh_token_expires_in" value="@((string)((context.Variables["tokenJson"] as Newtonsoft.Json.Linq.JObject)?["refresh_token_expires_in"]) ?? "0")" />
		<set-variable name="gcid" value="@( (string)((context.Variables["tokenJson"] as JObject)?["gcid"]) ?? "" )" />
		<set-variable name="scope" value="@( (string)((context.Variables["tokenJson"] as JObject)?["scope"]) ?? "" )" />
		<set-variable name="token_type" value="@( (string)((context.Variables["tokenJson"] as JObject)?["token_type"]) ?? "Bearer" )" />
		<set-variable name="expires_in" value="@((string)((context.Variables["tokenJson"] as Newtonsoft.Json.Linq.JObject)?["expires_in"]) ?? "0")" />
		<set-variable name="nonce" value="@( (string)((context.Variables["tokenJson"] as JObject)?["nonce"]) ?? "" )" />
		<set-variable name="id_token" value="@( (string)((context.Variables["tokenJson"] as JObject)?["id_token"]) )" />
		<choose>
			<when condition="@(!string.IsNullOrEmpty(context.Variables.GetValueOrDefault<string>("access_token"))
                     && !string.IsNullOrEmpty(context.Variables.GetValueOrDefault<string>("tokenBody")))">
				<cache-store-value key="@((string)context.Variables["access_token"])" value="@((string)context.Variables["tokenBody"])" duration="3600" caching-type="external" />
				<trace source="cachekey-info" severity="information">
					<message>@((string)context.Variables["access_token"])</message>
				</trace>
				<trace source="tokenbody-info" severity="information">
					<message>@((string)context.Variables["tokenBody"])</message>
				</trace>
			</when>
		</choose>
		<return-response>
			<set-status code="200" reason="OK" />
			<set-header name="Content-Type" exists-action="override">
				<value>application/json</value>
			</set-header>
			<set-body>@{
      var body = context.Variables["tokenBody"] as string ?? "";

      if (string.IsNullOrEmpty(body)) {
          return "{\"_dbg\":\"tokenBody is empty\"}";
      }
      return body;
  }</set-body>
		</return-response>
	</inbound>
	<backend>
		<base />
	</backend>
	<outbound>
		<base />
	</outbound>
	<on-error>
		<base />
	</on-error>
</policies>