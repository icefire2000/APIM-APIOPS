<policies>
	<inbound>
		<base />
		<choose>
			<when condition="@(!string.Equals(context.Request.Method, "GET", StringComparison.OrdinalIgnoreCase))">
				<return-response>
					<set-status code="405" reason="Method Not Allowed" />
					<set-header name="Allow" exists-action="override">
						<value>GET</value>
					</set-header>
					<set-header name="Content-Type" exists-action="override">
						<value>application/json</value>
					</set-header>
					<set-body>{"error":"method_not_allowed"}</set-body>
				</return-response>
			</when>
		</choose>
		<set-variable name="cacheKey" value="@((string)context.Request.Url.Query.GetValueOrDefault("key",""))" />
		<trace source="cachekey-info" severity="information">
			<message>@((string)context.Variables["cacheKey"])</message>
		</trace>
		<choose>
			<when condition="@(string.IsNullOrEmpty(context.Variables.GetValueOrDefault<string>("cacheKey")))">
				<return-response>
					<set-status code="400" reason="Bad Request" />
					<set-header name="Content-Type" exists-action="override">
						<value>application/json</value>
					</set-header>
					<set-body>{"error":"missing_cache_key"}</set-body>
				</return-response>
			</when>
		</choose>
		<cache-lookup-value key="@((string)context.Variables["cacheKey"])" default-value="" variable-name="cachedValue" caching-type="external" />
		<choose>
			<when condition="@(!string.IsNullOrEmpty(context.Variables.GetValueOrDefault<string>("cachedValue")))">
				<return-response>
					<set-status code="200" reason="OK" />
					<set-header name="Content-Type" exists-action="override">
						<value>application/json</value>
					</set-header>
					<set-body>@(context.Variables.GetValueOrDefault<string>("cachedValue"))</set-body>
				</return-response>
			</when>
			<otherwise>
				<return-response>
					<set-status code="404" reason="Not Found" />
					<set-header name="Content-Type" exists-action="override">
						<value>application/json</value>
					</set-header>
					<set-body>{"error":"cache_miss","key":"@(context.Variables.GetValueOrDefault["cacheKey"])"}</set-body>
				</return-response>
			</otherwise>
		</choose>
	</inbound>
	<backend>
		<base />
	</backend>
	<outbound>
		<base />
	</outbound>
	<on-error>
		<base />
		<set-header name="Content-Type" exists-action="override">
			<value>application/json</value>
		</set-header>
		<set-body>{"error":"internal_error"}</set-body>
	</on-error>
</policies>