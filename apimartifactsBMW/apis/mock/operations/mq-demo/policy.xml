<policies>
	<inbound>
		<base />
		<!-- 提取 orderId -->
		<set-variable name="orderId" value="@(context.Request.OriginalUrl.Query.GetValueOrDefault("orderid", string.Empty))" />
		<!-- 切换到 Function App 1 的基础地址 -->
		<set-backend-service base-url="https://apim-cms-backend.chinacloudsites.cn" />
		<!-- 重写路径 -->
		<rewrite-uri template="/api/Function1" />
		<!-- 设置查询参数 -->
		<set-query-parameter name="code" exists-action="override">
			<value>{{function1-key}}</value>
		</set-query-parameter>
		<set-query-parameter name="orderid" exists-action="override">
			<value>@((string)context.Variables["orderId"])</value>
		</set-query-parameter>
	</inbound>
	<backend>
		<forward-request timeout="30" />
	</backend>
	<outbound>
		<base />
	</outbound>
	<on-error>
		<send-request mode="new" response-variable-name="mqResponse" timeout="60">
			<set-url>https://apim-cms-backend.chinacloudsites.cn/api/Function2?code={{function2-key}}</set-url>
			<set-method>POST</set-method>
			<set-header name="Content-Type" exists-action="override">
				<value>application/json</value>
			</set-header>
			<set-body>@{  
              var orderId = (string)context.Variables["orderId"];  
              return $"{{ \"orderId\": \"{orderId}\" }}";  
            }</set-body>
		</send-request>
		<return-response>
			<set-status code="202" reason="Accepted" />
			<set-body>@{  
            var orderId = (string)context.Variables["orderId"];  
            return $"{{ \"message\": \"Order ID {orderId} has been added to the queue for processing.\" }}";  
          }</set-body>
		</return-response>
	</on-error>
</policies>