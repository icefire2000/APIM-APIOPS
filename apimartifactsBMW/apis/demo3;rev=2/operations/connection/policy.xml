<!--
    - Policies are applied in the order they appear.
    - Position <base/> inside a section to inherit policies from the outer scope.
    - Comments within policies are not preserved.
-->
<!-- Add policies as children to the <inbound>, <outbound>, <backend>, and <on-error> elements -->
<policies>
	<!-- Throttle, authorize, validate, cache, or transform the requests -->
	<inbound>
		<base />
		<send-request mode="new" response-variable-name="pingResponse" timeout="5" ignore-error="false">
			<set-url>https://forgerock-green.preprod-gcdm.cn-north-1.aws.cloud.bmw/am/json/authenticate</set-url>
			<set-method>GET</set-method>
		</send-request>
		<choose>
			<when condition="@( ((IResponse)context.Variables["pingResponse"]).StatusCode != 200 )">
				<return-response>
					<set-status code="502" reason="Bad Gateway" />
					<set-body>backend unreachable</set-body>
				</return-response>
			</when>
		</choose>
	</inbound>
	<!-- Control if and how the requests are forwarded to services  -->
	<backend>
		<base />
	</backend>
	<!-- Customize the responses -->
	<outbound>
		<base />
	</outbound>
	<!-- Handle exceptions and customize error responses  -->
	<on-error>
		<base />
	</on-error>
</policies>